// Private rule for LOLBAS system information gathering tools detection
// These patterns are reused across multiple threat and capability rules

rule lolbas_sysinfo
{
    strings:
        $whoami = /\bwhoami\b/
        // hostname only when invoked as a command, not as a quoted dict key
        $hostname = /(system|popen|exec\w*|spawn\w*|call|run|Popen|check_output|check_call)\s*\(\s*\[?\s*['"]hostname\b/ nocase

    condition:
        any of them
}
